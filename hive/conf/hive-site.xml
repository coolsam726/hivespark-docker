<?xml version="1.0" encoding="UTF-8"?>
<?xml-stylesheet type="text/xsl" href="configuration.xsl"?>
<configuration>

  <!-- ── Metastore JDBC connection to PostgreSQL ───────────────────────── -->
  <property>
    <name>javax.jdo.option.ConnectionURL</name>
    <value>jdbc:postgresql://postgres:5432/metastore</value>
  </property>

  <property>
    <name>javax.jdo.option.ConnectionDriverName</name>
    <value>org.postgresql.Driver</value>
  </property>

  <property>
    <name>javax.jdo.option.ConnectionUserName</name>
    <value>hive</value>
  </property>

  <property>
    <name>javax.jdo.option.ConnectionPassword</name>
    <value>hive</value>
  </property>

  <!-- ── Metastore Thrift service ──────────────────────────────────────── -->
  <property>
    <name>hive.metastore.uris</name>
    <value>thrift://hive-metastore:9083</value>
  </property>

  <property>
    <name>hive.metastore.port</name>
    <value>9083</value>
  </property>

  <!-- ── Warehouse location on HDFS ────────────────────────────────────── -->
  <property>
    <name>hive.metastore.warehouse.dir</name>
    <value>hdfs://namenode:9000/user/hive/warehouse</value>
  </property>
  <!-- Disable database notification API authentication: Trying to fix error with even notification poll -->
  <property>
    <name>hive.metastore.event.db.notification.api.auth</name>
    <value>false</value>
  </property>
  

  <!-- ── Schema validation ─────────────────────────────────────────────── -->
  <property>
    <name>hive.metastore.schema.verification</name>
    <value>false</value>
  </property>

  <!-- ── HiveServer2 ────────────────────────────────────────────────────── -->
  <property>
    <name>hive.server2.thrift.port</name>
    <value>10000</value>
  </property>

  <property>
    <name>hive.server2.webui.port</name>
    <value>10002</value>
  </property>

  <!-- Disable authentication for development -->
  <property>
    <name>hive.server2.authentication</name>
    <value>NONE</value>
  </property>

  <!-- ── Execution engine: Tez ────────────────────────────────────────── -->
  <property>
    <name>hive.execution.engine</name>
    <value>tez</value>
  </property>

  <!-- Path to the Tez tarball on HDFS (uploaded once by hiveserver2.sh) -->
  <property>
    <name>tez.lib.uris</name>
    <value>hdfs://namenode:9000/apps/tez/tez.tar.gz</value>
  </property>

  <!-- ── Auto-create metastore schema on first start ───────────────────── -->
  <property>
    <name>datanucleus.schema.autoCreateAll</name>
    <value>true</value>
  </property>

  <property>
    <name>datanucleus.autoCreateSchema</name>
    <value>true</value>
  </property>

  <!-- ── Disable stats auto-gather (speeds up dev queries) ─────────────── -->
  <property>
    <name>hive.stats.autogather</name>
    <value>false</value>
  </property>

  <!-- ── Authorization: disable SQL-std role enforcement (dev mode) ──────── -->
  <property>
    <name>hive.security.authorization.enabled</name>
    <value>false</value>
  </property>

  <property>
    <name>hive.security.authorization.manager</name>
    <value>org.apache.hadoop.hive.ql.security.authorization.DefaultHiveAuthorizationProvider</value>
  </property>

  <!-- Grant hive user admin rights for role management -->
  <property>
    <name>hive.users.in.admin.role</name>
    <value>hive</value>
  </property>

</configuration>
